#include <HardwareSerial.h>

// ===========================================================
//  CONFIGURATION & PIN DEFINITIONS
// ===========================================================

// UART connection from ESP32-CAM (Master RX=22, TX=17)
#define CAM_UART_RX_PIN 22 // Connected to CAM UOT (TX)
#define CAM_UART_TX_PIN 17 // Connected to CAM UOR (RX)
#define UART_BAUD 115200

// A4950 Motor Driver Pins
#define MOTOR_A_IN1 26 // AIN1
#define MOTOR_A_IN2 25 // AIN2
#define MOTOR_B_IN1 27 // BIN1
#define MOTOR_B_IN2 16 // BIN2

// Downward Facing IR Sensors (TRCT 5000)
#define IR_DOWN_FL 18
#define IR_DOWN_FR 19
#define IR_DOWN_BL 4
#define IR_DOWN_BR 5

// Front Facing Sensors
#define SENS_CENTER_E18 35
#define SENS_LEFT_SHARP 32
#define SENS_RIGHT_SHARP 33

// DIP Switches
#define DIP_SW1 21
#define DIP_SW2 14
#define DIP_SW3 12
#define DIP_SW4 13 // Safety switch

// LEDC PWM configuration
#define PWM_FREQ 5000    // 5 kHz
#define PWM_RESOLUTION 8 // 8-bit duty (0-255)

// Base speed and max speed (limited to 80% of 255 = ~204)
const int BASE_SPEED = 120;
const float STEER_SCALE = 1.0; 
const int MAX_PWM = 204;

const unsigned long LINK_TIMEOUT_MS = 500;

// ===========================================================
//  GLOBAL STATE
// ===========================================================
HardwareSerial CamLink(2); // UART2

String rxBuffer = "";
float steeringU = 0.0;
unsigned long lastPacketTime = 0;

enum RobotMode {
  MODE_IDLE,
  MODE_WAITING_AGIBOT,
  MODE_WAITING_SUMOBOT,
  MODE_AGIBOT,
  MODE_SUMOBOT_START,
  MODE_SUMOBOT
};

RobotMode currentMode = MODE_IDLE;
unsigned long stateStartTime = 0;

// ===========================================================
//  SETUP FUNCTIONS
// ===========================================================
void setupPWM() {
  ledcAttach(MOTOR_A_IN1, PWM_FREQ, PWM_RESOLUTION);
  ledcAttach(MOTOR_A_IN2, PWM_FREQ, PWM_RESOLUTION);
  ledcAttach(MOTOR_B_IN1, PWM_FREQ, PWM_RESOLUTION);
  ledcAttach(MOTOR_B_IN2, PWM_FREQ, PWM_RESOLUTION);

  // Ensure motors start stopped
  ledcWrite(MOTOR_A_IN1, 0);
  ledcWrite(MOTOR_A_IN2, 0);
  ledcWrite(MOTOR_B_IN1, 0);
  ledcWrite(MOTOR_B_IN2, 0);
}

void setupPins() {
  // Sensors
  pinMode(IR_DOWN_FL, INPUT);
  pinMode(IR_DOWN_FR, INPUT);
  pinMode(IR_DOWN_BL, INPUT);
  pinMode(IR_DOWN_BR, INPUT);
  
  pinMode(SENS_CENTER_E18, INPUT);
  pinMode(SENS_LEFT_SHARP, INPUT);
  pinMode(SENS_RIGHT_SHARP, INPUT);

  // DIP Switches
  pinMode(DIP_SW1, INPUT);
  pinMode(DIP_SW2, INPUT);
  pinMode(DIP_SW3, INPUT);
  pinMode(DIP_SW4, INPUT);
}

// ===========================================================
//  MOTOR DRIVE HELPER (A4950)
// ===========================================================
void driveMotor(int in1Pin, int in2Pin, int speed) {
  speed = constrain(speed, -MAX_PWM, MAX_PWM);

  if (speed >= 0) {
    ledcWrite(in1Pin, speed);
    ledcWrite(in2Pin, 0);
  } else {
    ledcWrite(in1Pin, 0);
    ledcWrite(in2Pin, -speed);
  }
}

void stopMotors() {
  driveMotor(MOTOR_A_IN1, MOTOR_A_IN2, 0);
  driveMotor(MOTOR_B_IN1, MOTOR_B_IN2, 0);
}

// Drive both motors forward
void driveForward(int speed) {
  driveMotor(MOTOR_A_IN1, MOTOR_A_IN2, speed);
  driveMotor(MOTOR_B_IN1, MOTOR_B_IN2, speed);
}

// ===========================================================
//  APPLY DIFFERENTIAL STEERING (AGIBOT)
// ===========================================================
void applySteering(float u) {
  float steer = u * STEER_SCALE;

  int leftSpeed = (int)(BASE_SPEED + steer);
  int rightSpeed = (int)(BASE_SPEED - steer);

  leftSpeed = constrain(leftSpeed, -MAX_PWM, MAX_PWM);
  rightSpeed = constrain(rightSpeed, -MAX_PWM, MAX_PWM);

  // Assuming Motor A is Left and Motor B is Right
  driveMotor(MOTOR_A_IN1, MOTOR_A_IN2, leftSpeed);
  driveMotor(MOTOR_B_IN1, MOTOR_B_IN2, rightSpeed);
}

// ===========================================================
//  NON-BLOCKING UART PACKET PARSER
// ===========================================================
void processPacket(const String &packet) {
  if (packet.length() < 5) return;
  if (packet.charAt(0) != '<') return;
  if (packet.charAt(packet.length() - 1) != '>') return;
  if (packet.charAt(1) != 'U' || packet.charAt(2) != ':') return;

  String valueStr = packet.substring(3, packet.length() - 1);
  steeringU = valueStr.toFloat();
  lastPacketTime = millis();
}

void parseIncomingSerial() {
  while (CamLink.available() > 0) {
    char c = (char)CamLink.read();

    if (c == '<') {
      rxBuffer = ""; // start of new packet
      rxBuffer += c;
    } else if (c == '>') {
      rxBuffer += c;
      processPacket(rxBuffer); 
      rxBuffer = "";
    } else if (c == '\n' || c == '\r') {
      // ignore
    } else {
      rxBuffer += c;
      if (rxBuffer.length() > 32) {
        rxBuffer = "";
      }
    }
  }
}

