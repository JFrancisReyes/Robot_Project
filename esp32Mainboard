// ===========================================================
//  SETUP
// ===========================================================
void setup() {
  Serial.begin(115200);
  CamLink.begin(UART_BAUD, SERIAL_8N1, CAM_UART_RX_PIN, CAM_UART_TX_PIN);

  setupPins();
  setupPWM();
  stopMotors();

  lastPacketTime = millis();
  Serial.println("Master ESP32 controller ready.");
}

// ===========================================================
//  MAIN LOOP
// ===========================================================
void loop() {
  // Always parse incoming serial to clear buffer
  parseIncomingSerial();

  bool sw1 = digitalRead(DIP_SW1);
  bool sw2 = digitalRead(DIP_SW2);
  bool sw4 = digitalRead(DIP_SW4);

  // Safety switch check
  if (!sw4) {
    if (currentMode != MODE_IDLE) {
      Serial.println("Safety Switch OFF. Entering IDLE mode.");
      currentMode = MODE_IDLE;
      stopMotors();
    }
  } else {
    // Mode Selection Logic
    if (sw1 && !sw2) {
      if (currentMode != MODE_AGIBOT && currentMode != MODE_WAITING_AGIBOT) {
        Serial.println("Switching to AgiBot Mode (10s Wait)...");
        currentMode = MODE_WAITING_AGIBOT;
        stateStartTime = millis();
        stopMotors();
      }
    } else if (!sw1 && sw2) {
      if (currentMode != MODE_SUMOBOT && currentMode != MODE_WAITING_SUMOBOT && currentMode != MODE_SUMOBOT_START) {
        Serial.println("Switching to Sumobot Mode (10s Wait)...");
        currentMode = MODE_WAITING_SUMOBOT;
        stateStartTime = millis();
        stopMotors();
      }
    } else {
      if (currentMode != MODE_IDLE) {
        Serial.println("No valid mode selected. Entering IDLE mode.");
        currentMode = MODE_IDLE;
        stopMotors();
      }
    }
  }

  // State Machine Execution
  unsigned long currentTime = millis();

  switch (currentMode) {
    case MODE_IDLE:
      stopMotors();
      break;

    case MODE_WAITING_AGIBOT:
      if (currentTime - stateStartTime >= 10000) {
        Serial.println("AgiBot Mode Active!");
        currentMode = MODE_AGIBOT;
        CamLink.println("<L:1>"); // Turn on ESP32Cam light
      }
      break;

    case MODE_AGIBOT:
      if (currentTime - lastPacketTime > LINK_TIMEOUT_MS) {
        stopMotors(); // Failsafe
      } else {
        applySteering(steeringU);
      }
      break;

    case MODE_WAITING_SUMOBOT:
      if (currentTime - stateStartTime >= 10000) {
        Serial.println("Sumobot Mode: Starting initial forward dash!");
        currentMode = MODE_SUMOBOT_START;
        stateStartTime = currentTime;
        driveForward(MAX_PWM); // Dash forward at max allowed speed
      }
      break;

    case MODE_SUMOBOT_START:
      if (currentTime - stateStartTime >= 3000) {
        Serial.println("Sumobot Mode Active!");
        currentMode = MODE_SUMOBOT;
        stopMotors();
      } else {
        driveForward(MAX_PWM);
      }
      break;

    case MODE_SUMOBOT:
      sumoLogic();
      break;
  }
}
